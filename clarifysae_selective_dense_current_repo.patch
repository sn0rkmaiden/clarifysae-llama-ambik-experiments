+def deterministic_subset(df: pd.DataFrame, *, n: int, seed: int, label: str) -> pd.DataFrame:
+    if n <= 0:
+        raise ValueError("subset size must be positive")
+    if n >= len(df):
+        return df.copy()
+    ranked: list[tuple[str, int]] = []
