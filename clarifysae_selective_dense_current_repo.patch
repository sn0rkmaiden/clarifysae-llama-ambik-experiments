+    }
+    return config
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--prefix", required=True)
+    parser.add_argument("--dataset", required=True)
+    parser.add_argument("--vector-path", required=True)
